# Base de données PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Authentification (minimum 32 caractères, à générer aléatoirement)
JWT_SECRET="your-secret-key-minimum-32-characters"

# Environnement : "development" ou "production"
NODE_ENV="production"

# URL publique de l'application (ex: déploiement Render)
APP_URL="https://your-app-url.onrender.com"

# Courriels transactionnels (Resend)
RESEND_API_KEY=

# Secret partagé pour protéger la route /api/cron/reminders
CRON_SECRET=

# Coordonnées affichées sur les reçus PDF envoyés automatiquement.
# La ventilation TPS/TVQ n'apparaît que si RECU_TPS et RECU_TVQ sont renseignés.
RECU_NOM="Centre Sportif de Haute-Performance"
RECU_ADRESSE=
RECU_TPS=
RECU_TVQ=
