generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String?
  lastName     String?
  phone        String?
  role         String   // ADMIN, SECTION_MANAGER, COACH
  section      String?  // Renseigné si le rôle est SECTION_MANAGER, ou comma separated
  remuneration Float?   @default(0)
  actif        Boolean  @default(true)
  dateDebut    DateTime @default(now())
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  grades       Grade[]  @relation("Examiner")
  courses      Course[]
}

model Member {
  id            String          @id @default(uuid())
  firstName     String
  lastName      String
  dateOfBirth   DateTime?
  gender        String?
  phone         String?
  email         String?
  photoUrl      String?
  status        String          @default("ACTIF") // ACTIF, INACTIF, EN_ATTENTE
  signupDate    DateTime        @default(now())
  notes         String?
  parentName    String?         // Pour les mineurs
  parentPhone   String?         // Pour les mineurs
  parentEmail    String?         // Courriel du parent pour les mineurs
  currentBelt   String?         @default("BLANCHE")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Infos personnelles additionnelles
  poids                  Float?

  // Contrat
  dateInscription        DateTime?
  finContrat             DateTime?

  // Plan tarifaire
  plan                   Plan?       // 'MENSUEL', 'TRIMESTRIEL', 'ANNUEL'
  prixBase               Float?
  rabaisFamille          Boolean     @default(false)
  membreFamilleId        String?
  rabaisCustomPct        Float?
  raisonRabaisCustom     String?
  montantFinal           Float?

  // Référencement
  referePar              String?
  rabaisReferentPct      Float?
  rabaisReferentApplique Boolean     @default(false)

  // Consentement au règlement intérieur (inscription en ligne)
  reglementVersion       String?     // version du règlement acceptée
  reglementAccepteAt     DateTime?   // horodatage de l'acceptation
  reglementSignataire    String?     // nom complet saisi comme signature

  // Relations
  sections      MemberSection[]
  attendances   Attendance[]
  grades        Grade[]
  versements    PaymentVersement[]
}

model PaymentVersement {
  id              String    @id @default(uuid())
  membreId        String
  numeroVersement Int
  montant         Float
  datePrevue      DateTime
  datePaiement    DateTime?
  methodePaiement MethodePaiement?   // CASH, VIREMENT, CHEQUE, CARTE
  note            String?
  reminderSentAt  DateTime?          // Anti-doublon pour les rappels de paiement automatiques
  receiptNumber   Int?               // Numéro de reçu (assigné à l'envoi du reçu)
  receiptSentAt   DateTime?          // Date d'envoi du reçu par courriel (anti-doublon)
  createdAt       DateTime  @default(now())

  member          Member    @relation(fields: [membreId], references: [id], onDelete: Cascade)
}

model MemberSection {
  id             String   @id @default(uuid())
  memberId       String
  section        String   // KARATE, JUDO, NINJAS_GR1, NINJAS_GR2, TAEKWONDO, KICKBOXING, FITNESS, PRIVATE
  belt           String?  @default("Blanche")
  enrollmentDate DateTime @default(now())
  
  member         Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, section])
}

model Course {
  id        String   @id @default(uuid())
  section   String
  startTime String   // "17:00"
  endTime   String   // "18:30"
  coachId   String?
  jours     String[] // ["LUN", "MER", "VEN"]
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())

  coach       User?        @relation(fields: [coachId], references: [id], onDelete: SetNull)
  attendances Attendance[]
}

model Attendance {
  id        String   @id @default(uuid())
  memberId  String
  courseId  String
  date      DateTime
  status    String   @default("PRESENT") // PRESENT, ABSENT, EXCUSED

  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([memberId, courseId, date])
}

model Grade {
  id                 String   @id @default(uuid())
  memberId           String
  section            String
  ceinturePrecedente String
  ceintureMontante   String
  date               DateTime
  examinateurId      String
  note               String?
  createdAt          DateTime @default(now())

  member             Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  examinateur        User     @relation("Examiner", fields: [examinateurId], references: [id])
}

model Lead {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  gender      String?
  phone       String?
  email       String?
  sport       String   // KARATE, JUDO, TAEKWONDO, KICKBOXING, PRIVATE
  requestType String   // ESSAI, RAPPEL, TARIFS, AUTRE
  status      String   @default("NEW") // NEW, CONTACTED, CONVERTED, LOST
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Section {
  id        String   @id @default(uuid())
  code      String   @unique  // ex: "KARATE_GR1"
  label     String            // ex: "Karaté Gr. 1"
  sport     String            // ex: "KARATE", "JUDO", "NINJAS"
  ordre     Int      @default(0)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum Plan {
  MENSUEL
  TRIMESTRIEL
  ANNUEL
}

enum MethodePaiement {
  CASH
  VIREMENT
  CHEQUE
  CARTE
}

model MasseSalariale {
  id        String   @id @default(uuid())
  mois      Int      // 1-12
  annee     Int      // 2024, 2025, 2026
  montant   Float
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([mois, annee])  // un seul enregistrement par mois
}

model CoachSalaire {
  id        String   @id @default(uuid())
  nom       String
  montant   Float
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Config de base pour les charges avec hausse automatique annuelle
model DepenseConfig {
  id            String   @id @default(uuid())
  code          String   @unique   // ex: "LOYER"
  label         String             // ex: "Loyer"
  montantBase   Float              // montant de référence
  anneeBase     Int                // année du montantBase (ex: 2024)
  tauxHaussePct Float    @default(0) // ex: 2.0 pour +2%/an automatique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Charges mensuelles ou annuelles, fixes ou variables
model Depense {
  id          String          @id @default(uuid())
  label       String
  montant     Float
  mois        Int?            // 1-12 = mois précis | null = tous les mois de l'année
  annee       Int
  categorie   CategorieDepense @default(FIXE)
  note        String?
  isOverride  Boolean         @default(false) // true si saisie manuelle sur config auto
  configCode  String?         // référence à DepenseConfig.code si override
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum CategorieDepense {
  FIXE
  VARIABLE
  SALARIALE
  AUTRE
}




