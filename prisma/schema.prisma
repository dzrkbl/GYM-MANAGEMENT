generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String?
  lastName     String?
  phone        String?
  role         String   // ADMIN, SECTION_MANAGER, COACH
  section      String?  // Renseigné si le rôle est SECTION_MANAGER, ou comma separated
  remuneration Float?   @default(0)
  actif        Boolean  @default(true)
  dateDebut    DateTime @default(now())
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  grades       Grade[]  @relation("Examiner")
  courses      Course[]
}

model Member {
  id            String          @id @default(uuid())
  firstName     String
  lastName      String
  dateOfBirth   DateTime?
  gender        String?
  phone         String?
  email         String?
  photoUrl      String?
  status        String          @default("ACTIF") // ACTIF, INACTIF, EN_ATTENTE
  signupDate    DateTime        @default(now())
  notes         String?
  parentName    String?         // Pour les mineurs
  parentPhone   String?         // Pour les mineurs
  currentBelt   String?         @default("BLANCHE")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Infos personnelles additionnelles
  poids                  Float?
  groupe                 String?     // 'KARATE_GR1', 'KARATE_GR2', 'JUDO_GR1', 'JUDO_GR2', 'JUDO_GR3', 'NINJAS_GR1', 'NINJAS_GR2', 'MENSUEL'

  // Contrat
  dateInscription        DateTime?
  finContrat             DateTime?

  // Plan tarifaire
  plan                   Plan?       // 'MENSUEL', 'TRIMESTRIEL', 'ANNUEL'
  prixBase               Float?
  rabaisFamille          Boolean     @default(false)
  membreFamilleId        String?
  rabaisCustomPct        Float?
  raisonRabaisCustom     String?
  montantFinal           Float?

  // Référencement
  referePar              String?
  rabaisReferentPct      Float?
  rabaisReferentApplique Boolean     @default(false)

  // Relations
  sections      MemberSection[]
  subscriptions Subscription[]
  payments      Payment[]
  attendances   Attendance[]
  grades        Grade[]
  versements    PaymentVersement[]
}

model PaymentVersement {
  id              String    @id @default(uuid())
  membreId        String
  numeroVersement Int
  montant         Float
  datePrevue      DateTime
  datePaiement    DateTime?
  methodePaiement MethodePaiement?   // CASH, VIREMENT, CHEQUE, CARTE
  note            String?
  createdAt       DateTime  @default(now())

  member          Member    @relation(fields: [membreId], references: [id], onDelete: Cascade)
}

model MemberSection {
  id             String   @id @default(uuid())
  memberId       String
  section        String   // KARATE, JUDO, NINJAS_GR1, NINJAS_GR2, TAEKWONDO, KICKBOXING, FITNESS, PRIVATE
  belt           String?  @default("Blanche")
  enrollmentDate DateTime @default(now())
  
  member         Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, section])
}

model Subscription {
  id        String   @id @default(uuid())
  memberId  String
  section   String   // Lier l'abonnement à une section (ex: KARATE)
  type      String   // MONTHLY, QUARTERLY
  amount    Float
  startDate DateTime
  endDate   DateTime
  status    String   @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  payments  Payment[]
}

model Payment {
  id             String        @id @default(uuid())
  subscriptionId String?
  memberId       String
  amount         Float
  method         PaymentMethod?       // CASH, TRANSFER, CARD
  dueDate        DateTime
  paidDate       DateTime?
  status         String        @default("PENDING") // PAID, PENDING, OVERDUE
  reminderSentAt DateTime?     // Évite les doublons d'alertes
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  member         Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
}



model Course {
  id        String   @id @default(uuid())
  section   String
  startTime String   // "17:00"
  endTime   String   // "18:30"
  coachId   String?
  jours     String[] // ["LUN", "MER", "VEN"]
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())

  coach       User?        @relation(fields: [coachId], references: [id], onDelete: SetNull)
  attendances Attendance[]
}

model Attendance {
  id        String   @id @default(uuid())
  memberId  String
  courseId  String
  date      DateTime
  status    String   @default("PRESENT") // PRESENT, ABSENT, EXCUSED

  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([memberId, courseId, date])
}

model Grade {
  id                 String   @id @default(uuid())
  memberId           String
  section            String
  ceinturePrecedente String
  ceintureMontante   String
  date               DateTime
  examinateurId      String
  note               String?
  createdAt          DateTime @default(now())

  member             Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  examinateur        User     @relation("Examiner", fields: [examinateurId], references: [id])
}

model Lead {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  gender      String?
  phone       String?
  email       String?
  sport       String   // KARATE, JUDO, TAEKWONDO, KICKBOXING, PRIVATE
  requestType String   // ESSAI, RAPPEL, TARIFS, AUTRE
  status      String   @default("NEW") // NEW, CONTACTED, CONVERTED, LOST
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Section {
  id        String   @id @default(uuid())
  code      String   @unique  // ex: "KARATE_GR1"
  label     String            // ex: "Karaté Gr. 1"
  sport     String            // ex: "KARATE", "JUDO", "NINJAS"
  ordre     Int      @default(0)
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum Plan {
  MENSUEL
  TRIMESTRIEL
  ANNUEL
}

enum MethodePaiement {
  CASH
  VIREMENT
  CHEQUE
  CARTE
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
}

